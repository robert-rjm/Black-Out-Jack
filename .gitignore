.pytest_cache/
pytest-cache-files-*/

# Regenerated by `python scripts/simulation.py` on every run — not tracked.
# Use `python scripts/snapshot.py <label>` to deliberately save a copy under
# scripts/snapshots/<label>/, which IS tracked.
scripts/simulation_log.csv
scripts/simulation_results.txt
scripts/benchmarks.json

# Decision-log exports — real session data, not code, but no longer gitignored.
data/drinks/

# Claude Code local settings — machine-specific, not shared.
.claude/

# Regenerated from source on every app startup (app/services/asset_bundler.py)
# — not source, not tracked.
static/js/bundle.js
static/css/bundle.css
